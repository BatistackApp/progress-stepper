{
    "name": "webkul/progress-stepper",
    "description": "A Filament v5 progress-stepper form & infolist component for visualising workflow state as a horizontal arrow-stepper.",
    "keywords": [
        "webkul",
        "laravel",
        "filamentphp",
        "filament",
        "filament-plugin",
        "progress-stepper"
    ],
    "homepage": "https://github.com/webkul/progress-stepper",
    "license": "MIT",
    "authors": [
        {
            "name": "Webkul",
            "email": "support@webkul.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "filament/filament": "^5.0",
        "filament/forms": "^5.0",
        "filament/infolists": "^5.0",
        "spatie/laravel-package-tools": "^1.15"
    },
    "autoload": {
        "psr-4": {
            "Webkul\\ProgressStepper\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Webkul\\ProgressStepper\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Webkul\\ProgressStepper\\ProgressStepperServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
